      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket{application=\"whatiread\"}[5m])) by (le, table, operation))",
          "legendFormat": "{{table}} {{operation}} p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(jdbc_query_seconds_bucket{application=\"whatiread\"}[5m])) by (le))",
          "legendFormat": "jdbc p95",
          "refId": "B"
        }
      ],
      "title": "DB query latency p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
