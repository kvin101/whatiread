# Copy to .env before running compose stacks that read this file:
#   docker compose up --build                          (local dev, builds images)
#   docker compose -f docker-prod-compose.yml up -d      (production, pulls from Docker Hub)
#
# Self-hosting with your own reverse proxy: use docker-selfhost-compose.yml instead —
# it inlines environment values in the compose file (edit CHANGE_ME_* placeholders there).

POSTGRES_PASSWORD=change-me-use-a-strong-password
JWT_SECRET=change-me-use-at-least-32-characters-long-secret

# Public registration (default false in Docker prod stack)
REGISTRATION_ENABLED=false

CORS_ORIGINS=http://localhost
GOOGLE_BOOKS_API_KEY=

# Meilisearch search index and API key used by the API container
MEILISEARCH_MASTER_KEY=change-me-use-a-strong-meilisearch-master-key
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=
MEILISEARCH_ENABLED=true
MEILISEARCH_INDEX=book-suggest
MEILISEARCH_USER_INDEX=user-suggest
MEILISEARCH_SEED_RESOURCE=classpath:book-suggest/book-suggest.json
MEILISEARCH_LOAD_SEED_ON_STARTUP=true
MEILISEARCH_LOAD_USERS_ON_STARTUP=true

# Avatar files persisted by the API container
WHATIREAD_AVATARS_DIRECTORY=./data/avatars

# Published web port (nginx serves UI + proxies /api and /ws)
HTTP_PORT=80

# Optional image tag for releases
IMAGE_TAG=latest

# Rate limiting (API container)
RATE_LIMIT_ENABLED=true

# Observability stack (otel-collector, prometheus, grafana, jaeger, loki).
# false: set COMPOSE_PROFILES= (empty) and OTEL_SDK_DISABLED=true
# true:  set COMPOSE_PROFILES=observability (default below)
OBSERVABILITY_ENABLED=true
COMPOSE_PROFILES=observability
OTEL_SDK_DISABLED=false

# Tail-based trace sampling (otel-collector). The API exports 100% of spans.
OTEL_TAIL_SAMPLING_DECISION_WAIT=10s
OTEL_TAIL_SAMPLING_SLOW_MS=2000
OTEL_TAIL_SAMPLING_CRITICAL_PERCENT=50
OTEL_TAIL_SAMPLING_NORMAL_PERCENT=5

# Grafana — login required by default (anonymous admin disabled)
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin-password
# Set GRAFANA_ANONYMOUS=true only on a trusted local machine:
# GRAFANA_ANONYMOUS=true
# GRAFANA_DISABLE_LOGIN=true
