# WhatIRead — Docker Compose
#
#   docker compose up --build -d
#
# Pull images instead of building: set API_IMAGE and WEB_IMAGE below.

# --- Required ---

POSTGRES_PASSWORD=change-me-use-a-strong-password
JWT_SECRET=change-me-use-at-least-32-characters-long-secret
MEILISEARCH_MASTER_KEY=change-me-use-a-strong-meilisearch-master-key

# --- App ---

REGISTRATION_ENABLED=false
CORS_ORIGINS=http://localhost
GOOGLE_BOOKS_API_KEY=
HTTP_PORT=80
RATE_LIMIT_ENABLED=true

# --- Meilisearch ---

MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=
MEILISEARCH_ENABLED=true
MEILISEARCH_LOAD_SEED_ON_STARTUP=true
MEILISEARCH_LOAD_USERS_ON_STARTUP=true
MEILI_ENV=development

# --- Images (unset = build from source) ---

IMAGE_TAG=latest
# API_IMAGE=vinayk101/whatiread-api:latest
# WEB_IMAGE=vinayk101/whatiread-web:latest

# --- Observability (on by default) ---
#
# COMPOSE_PROFILES: obs-prometheus, obs-jaeger, obs-otel, obs-loki, obs-grafana
# To disable: clear COMPOSE_PROFILES and set OBSERVABILITY_ENABLED=false, OTEL_SDK_DISABLED=true, WHATIREAD_LOKI_URL=

COMPOSE_PROFILES=obs-prometheus,obs-jaeger,obs-otel,obs-loki,obs-grafana
OBSERVABILITY_ENABLED=true
OTEL_SDK_DISABLED=false
WHATIREAD_LOKI_URL=http://loki:3100/loki/api/v1/push
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin-password

OTEL_TAIL_SAMPLING_DECISION_WAIT=10s
OTEL_TAIL_SAMPLING_SLOW_MS=2000
OTEL_TAIL_SAMPLING_CRITICAL_PERCENT=50
OTEL_TAIL_SAMPLING_NORMAL_PERCENT=5
